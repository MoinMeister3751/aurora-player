# Spotify Developer Dashboard → your app → Settings
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id_here

# Must be registered 1:1 (byte-for-byte) in the Spotify Dashboard under
# "Redirect URIs" — no trailing slash, no extra path unless you add one on
# both sides. Port must match VITE_SPOTIFY_LOOPBACK_PORT below.
VITE_SPOTIFY_REDIRECT_URI=http://127.0.0.1:17845

# Local loopback port used to catch the OAuth redirect (RFC 8252).
# Pick any free port; keep it in sync with the redirect URI above.
VITE_SPOTIFY_LOOPBACK_PORT=17845
