{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aurora",
  "version": "0.1.5",
  "identifier": "com.aurora.player",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Aurora",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "backgroundColor": "#0a0a0c"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' https://i.scdn.co https://image-cdn-ak.spotifycdn.com data: blob:; media-src 'self' blob:; connect-src 'self' https://api.spotify.com https://accounts.spotify.com https://sdk.scdn.co https://i.scdn.co https://image-cdn-ak.spotifycdn.com; script-src 'self' https://sdk.scdn.co; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUzNDY4NDBBQkZFQTEzRDAKUldUUUUrcS9Db1JHVSs5RDQvcHhTQks2K2o2VlZDd1IrOGZGa05kcUE5TXV0eXFWbU5JNnQwK3YK",
      "endpoints": [
        "https://github.com/MoinMeister3751/aurora-player/releases/latest/download/latest.json"
      ]
    }
  }
}
